# Forensic evidence output — never commit captured screenshots / case data.
# The companion writes here when DFIR_CASES_ROOT points outside companion/
# (e.g. the default-ish ../cases). Keep it out of git.
/cases/

# Secrets / local config
**/.env

# Node
node_modules/
dist/
*.timestamp-*.mjs
.gstack/

# Docker: the pre-built browser add-on the companion container copies out for "Load unpacked".
/addon/

# Atomic-write temp files. atomicWrite.ts writes `<target>.tmp` then renames it over
# the target; formatters (Prettier-style write-file-atomic) write `<src>.tmp.<pid>.<hex>`.
# In a Dropbox/OneDrive-synced tree a sync/AV lock can orphan one mid-rename — keep these
# out of git so `git add -A` never sweeps them in.
*.tmp
*.tmp.*

# Local planning / process scratch (not part of the shipped project)
.planning/
docs/superpowers/
